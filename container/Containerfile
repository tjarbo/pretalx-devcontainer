FROM mcr.microsoft.com/devcontainers/python:3.14

RUN apt update && \
    apt install -y libffi-dev gettext build-essential && \
    pip3 install setuptools wheel Faker uv && \
    # Adding redis within the container image to include all the necessary dependencies for pretalx.
    # This reduces the maintenance work for devcontainer users to upgrade their setup just because pretalx adds a new dependency.
    apt install -y redis-server

# Install just - task runner
RUN uv tool install rust-just --directory /usr/local/bin

COPY default-scripts /opt/pretalx-devcontainer/default-scripts

RUN chmod +x /opt/pretalx-devcontainer/default-scripts/start-container.sh

ENTRYPOINT ["/opt/pretalx-devcontainer/default-scripts/start-container.sh"]
CMD ["sleep", "infinity"]
